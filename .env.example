# Supabase
SUPABASE_URL=https://your-project.supabase.co
# Web tier — respects RLS policies, used by /api/digest, /api/categories.
SUPABASE_ANON_KEY=your-anon-key
# Pipeline + admin routes — full read/write, bypasses RLS.
SUPABASE_SERVICE_KEY=your-service-role-key

# Server
PORT=3001
NODE_ENV=development
# Bearer token required for /api/admin/* routes. Generate with: openssl rand -hex 32
ADMIN_TOKEN=generate-a-random-string

# Pipeline (Python)
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# Email (Resend) — subscribers themselves come from the DB table
RESEND_API_KEY=your-resend-key
EMAIL_FROM=digest@yourdomain.com
